# ── Supabase Client (browser/mobile — bundled, anon key only) ──────────────────
# These are safe to bundle into the Expo client. Use the anon/publishable key only.
# NEVER put the service role key under an EXPO_PUBLIC_ prefix.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase Server-Side (Edge Functions only — NEVER prefix EXPO_PUBLIC_) ──────
# The service role key bypasses RLS. Keep it exclusively in Edge Function secrets
# or server-side environments. Never expose it in the mobile/web bundle.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Database Connections ─────────────────────────────────────────────────────────
# Edge Functions / serverless — use pooled connection (port 6543, transaction mode)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Supabase CLI migrations only — use direct connection (port 5432, session mode)
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Raw DB password (used by supabase CLI for db push/reset)
SUPABASE_DB_PASSWORD=

# ── Optional vendor integrations ─────────────────────────────────────────────────
EXPO_PUBLIC_MAPS_API_KEY=
EXPO_PUBLIC_CRASH_REPORTING_KEY=
